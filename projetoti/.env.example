DB_HOST=localhost
DB_USER=root
DB_PASS=senha_mysql
PORT=3000
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=sua_chave_jwt
LLM_PROVIDER=gemini
GEMINI_API_KEY=sua_chave_api
GEMINI_MODEL=gemini-2.5-flash
LLM_TIMEOUT_MS=20000
LLM_TEMPERATURE=0.2
GEMINI_MAX_OUTPUT_TOKENS=900
OPENSKY_CLIENT_ID=seu_client_id
OPENSKY_CLIENT_SECRET=seu_client_secret
# Alternativa legado, se nao usar OAuth client credentials:
OPENSKY_USERNAME=seu_usuario
OPENSKY_PASSWORD=sua_senha
AERODATABOX_API_KEY=sua_api_key
LIVE_AERODATABOX_DELAY_MS=1200
LIVE_FLIGHTS_AIRPORTS=GRU
LIVE_FLIGHTS_CACHE_TTL=40

# true = modo demonstracao completo: backend/auth/ia ficam ativos, mas IA generativa/LLM fica desligada
DEMO_MODE=false
